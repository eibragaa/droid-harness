<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when Dark Mode is on -->
    <style name="LaunchTheme" parent="@android:style/Theme.Material.NoActionBar">
        <!-- Customize your splash screen theme here -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started -->
    <style name="NormalTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
